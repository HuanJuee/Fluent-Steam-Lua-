<Window x:Class="SteamLuaManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        Title="Fluent Steam Lua 管理工具"
        Icon="pack://application:,,,/Assets/app.ico"
        Height="700" Width="1050"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Acrylic10"
        ui:WindowHelper.Acrylic10Color="#CC1E1E1E"
        ui:WindowHelper.CornerStyle="Round"
        ui:WindowHelper.FixMaximizedWindow="True"
        ui:TitleBar.Height="40"
        Background="Transparent"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop"
        Loaded="Window_Loaded"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled">

    <Grid Background="Transparent">
        <ui:NavigationView x:Name="NavView"
                           PaneDisplayMode="Left"
                           IsPaneOpen="False"
                            OpenPaneLength="110"
                            CompactPaneLength="48"
                           IsSettingsVisible="False"
                           IsBackEnabled="False"
                           IsBackButtonVisible="Collapsed"
                           SelectionChanged="NavView_SelectionChanged"
                           Background="Transparent">
            <ui:NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <Thickness x:Key="NavigationViewBorderThickness">0</Thickness>
            </ui:NavigationView.Resources>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem x:Name="HomeItem" Content="主页" Tag="Home" Padding="12,0">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE80F;" FontSize="16"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="ScriptDownloadItem" Content="入库" Tag="ScriptDownload" Padding="12,0">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE990;" FontSize="16"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem x:Name="SettingsItem" Content="设置" Tag="Settings" Padding="12,0">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE713;" FontSize="16"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem x:Name="AboutItem" Content="关于" Tag="About" Padding="12,0">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE9CE;" FontSize="16"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>

            <!-- 主内容区域 -->
            <Grid>
                <Border VerticalAlignment="Stretch" HorizontalAlignment="Left"
                        Width="1" Background="#30FFFFFF" Margin="1,8,0,8"/>
                <ui:TransitioningContentControl x:Name="ContentTransition"
                                                 Transition="RightReplace"
                                                 Background="{x:Null}"/>
            </Grid>
        </ui:NavigationView>
    </Grid>
</Window>
