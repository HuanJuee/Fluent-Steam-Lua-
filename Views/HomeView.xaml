<UserControl x:Class="SteamLuaManager.Views.HomeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
        xmlns:controls="clr-namespace:SteamLuaManager.Controls"
        Background="Transparent">

    <Grid>

        <ikw:SimpleStackPanel Margin="24,16,24,16">

        <!-- 顶部标题区域 -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="已入库的游戏" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="{Binding StatusText}" FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding RefreshGamesCommand}" Padding="12,6" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE72C;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="刷新" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding AddFilesCommand}" Padding="12,6" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE710;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="添加文件" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenLuaFolderCommand}" Padding="12,6" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE838;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="打开目录" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 搜索、视图、排序栏 -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:AutoSuggestBox Grid.Column="0" x:Name="SearchBox"
                               PlaceholderText="搜索游戏名称或 AppID"
                               QuerySubmitted="SearchBox_QuerySubmitted"
                               TextChanged="SearchBox_TextChanged"
                               Margin="0,0,12,0" HorizontalAlignment="Stretch"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                <TextBlock Text="视图:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ComboBox x:Name="ViewModeComboBox"
                          SelectedValuePath="Content"
                          SelectedValue="{Binding SelectedViewMode, Mode=TwoWay}"
                          Width="100" Padding="12,6"
                          HorizontalContentAlignment="Center">
                    <ComboBoxItem Content="卡片"/>
                    <ComboBoxItem Content="列表"/>
                    <ComboBoxItem Content="表格"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="排序:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ComboBox x:Name="SortComboBox"
                          SelectedValuePath="Content"
                          SelectedValue="{Binding SelectedSortOption, Mode=TwoWay}"
                          Width="140" Padding="12,6"
                          HorizontalContentAlignment="Center">
                    <ComboBoxItem Content="名称 A-Z"/>
                    <ComboBoxItem Content="名称 Z-A"/>
                    <ComboBoxItem Content="AppID 升序"/>
                    <ComboBoxItem Content="AppID 降序"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Loading提示 -->
        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0"
                    Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVisibilityConverter}}">
            <ui:ProgressRing IsActive="True" Width="32" Height="32" Margin="0,0,0,12"/>
            <TextBlock Text="正在加载游戏信息..." HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- 游戏内容区域（非加载 且 有游戏时显示） -->
        <Grid Visibility="{Binding IsRefreshing, Converter={StaticResource InvertedBoolToVisibilityConverter}}">

            <!-- 卡片模式 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Loaded="ViewModeContainer_Loaded"
                          Visibility="{Binding SelectedViewMode, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=卡片}">
                <ItemsControl ItemsSource="{Binding Games}" Margin="0,0,0,16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:ClippingBorder Margin="0,0,16,16" Width="220" CornerRadius="12"
                                    Background="#30000000"
                                    BorderBrush="#25FFFFFF"
                                    BorderThickness="1"
                                    Tag="{Binding}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="120"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Rectangle Grid.Row="0" Fill="#25000000"/>
                                    <Image Grid.Row="0"
                                           Source="{Binding CoverImagePath, Converter={StaticResource FilePathToImageConverter}}"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>

                                    <TextBlock Grid.Row="1" Text="{Binding GameName}"
                                               FontWeight="SemiBold" FontSize="14"
                                               Margin="12,10,12,2" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                    <TextBlock Grid.Row="2" FontSize="12" Margin="12,0,12,8"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="AppID: "/>
                                        <Run Text="{Binding AppId, Mode=OneWay}"/>
                                    </TextBlock>

                                    <Button Grid.Row="3" Tag="{Binding}" Click="MoreButton_Click"
                                            HorizontalAlignment="Right" Margin="0,0,8,8"
                                            Padding="6,4" FontSize="12" Background="Transparent" BorderThickness="0">
                                        <ui:FontIcon Glyph="&#xE712;" FontSize="16"/>
                                    </Button>
                                </Grid>
                            </controls:ClippingBorder>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 列表模式 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Loaded="ViewModeContainer_Loaded"
                          Visibility="{Binding SelectedViewMode, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=列表}">
                <StackPanel Margin="0,0,0,16">
                    <ItemsControl ItemsSource="{Binding Games}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#30000000" CornerRadius="8" Margin="0,0,0,6" Padding="12"
                                        BorderBrush="#20FFFFFF" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" CornerRadius="6" ClipToBounds="True"
                                                Width="120" Height="52" Background="#25000000"
                                                BorderBrush="#20FFFFFF" BorderThickness="1">
                                            <Image Source="{Binding CoverImagePath, Converter={StaticResource FilePathToImageConverter}}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0">
                                            <TextBlock Text="{Binding GameName}" FontWeight="SemiBold" FontSize="14"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock FontSize="12" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                <Run Text="AppID: "/>
                                                <Run Text="{Binding AppId, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Grid.Column="2" Tag="{Binding}" Click="MoreButton_Click"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Padding="8,6" Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                            <ui:FontIcon Glyph="&#xE712;" FontSize="16"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- 表格模式 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Loaded="ViewModeContainer_Loaded"
                          Visibility="{Binding SelectedViewMode, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=表格}">
                <Grid Margin="0,0,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#40000000" CornerRadius="8,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="游戏名称" FontWeight="SemiBold" FontSize="13" Padding="14,10"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="AppID" FontWeight="SemiBold" FontSize="13" Padding="14,10"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" FontSize="13" Padding="14,10"/>
                        </Grid>
                    </Border>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Games}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#15FFFFFF" BorderThickness="0,0,0,1" Padding="0"
                                        Background="#20000000">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding GameName}" FontSize="13" Padding="14,9"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding AppId}" FontSize="13" Padding="14,9"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <Button Grid.Column="2" Tag="{Binding}" Click="MoreButton_Click"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Padding="6,4" Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                            <ui:FontIcon Glyph="&#xE712;" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- 空状态提示 -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60,0,0"
                    Visibility="{Binding Games.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
            <ui:FontIcon Glyph="&#xE7F0;" FontSize="48" HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            <TextBlock Text="还没有入库的游戏" FontSize="18" HorizontalAlignment="Center" Margin="0,16,0,8"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <TextBlock Text="将 .lua 文件拖拽到此处，或点击上方添加文件按钮" FontSize="13"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
        </StackPanel>

    </ikw:SimpleStackPanel>

        <!-- 慢速获取浮层 -->
        <Border Visibility="{Binding IsRefreshSlow, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="#CC1E1E1E" IsHitTestVisible="True">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="32">
                <Border CornerRadius="12" Background="#2A2A2A" Padding="32"
                        BorderBrush="#30FFFFFF" BorderThickness="1"
                        MaxWidth="400">
                    <StackPanel HorizontalAlignment="Center" Width="280">

                        <ui:FontIcon Glyph="&#xE7BA;" FontSize="36" HorizontalAlignment="Center"
                                     Foreground="White"/>
                        <TextBlock Text="获取游戏信息较慢" FontSize="20" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                        <TextBlock Text="{Binding RefreshProgressText}" FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"
                                   Foreground="White"/>

                        <ui:ProgressRing IsActive="True" Width="24" Height="24" Margin="0,0,0,12"/>

                        <TextBlock Text="已超过20秒，后台仍在尝试获取中..."
                                   FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Text="提示：&#x0a;• 可尝试开启 VPN / 代理&#x0a;• 或前往 设置 → 封面CDN节点 切换试试"
                                   FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,8,0,16"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                        <Button Content="取消获取" Command="{Binding CancelRefreshCommand}"
                                Padding="24,10" HorizontalAlignment="Center"
                                Background="#4CAF50" Foreground="White"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>
