<UserControl x:Class="SteamLuaManager.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="36,24,36,24" HorizontalAlignment="Stretch">

            <!-- 页面标题 -->
            <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,28"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

            <!-- 分类标签栏（蓝色下划线） -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Border x:Name="BasicTab" Padding="16,10" Margin="0,0,4,0"
                        Cursor="Hand" Background="Transparent" BorderThickness="0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding SwitchSettingsCategoryCommand}"
                                      CommandParameter="Basic"/>
                    </Border.InputBindings>
                    <StackPanel Orientation="Vertical">
                        <TextBlock x:Name="BasicTabText" Text="基本设置" FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <Border x:Name="BasicUnderline" Height="3" Width="24" CornerRadius="1.5"
                                Background="#2196F3" HorizontalAlignment="Center" Margin="0,4,0,0"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
                <Border x:Name="AdvancedTab" Padding="16,10" Margin="4,0,0,0"
                        Cursor="Hand" Background="Transparent" BorderThickness="0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding SwitchSettingsCategoryCommand}"
                                      CommandParameter="Advanced"/>
                    </Border.InputBindings>
                    <StackPanel Orientation="Vertical">
                        <TextBlock x:Name="AdvancedTabText" Text="高级设置" FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <Border x:Name="AdvancedUnderline" Height="3" Width="24" CornerRadius="1.5"
                                Background="#2196F3" HorizontalAlignment="Center" Margin="0,4,0,0"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 分割线 -->
            <Rectangle Height="1" Fill="#30FFFFFF" Margin="0,0,0,16"/>

            <!-- ============================================================ -->
            <!-- 基本设置 -->
            <!-- ============================================================ -->
            <StackPanel x:Name="BasicSection" Opacity="1" Visibility="Visible">

                <!-- Steam 路径 -->
                <Border Background="#28000000" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                        BorderBrush="#08FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="Steam 路径" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="选择Steam安装路径，留空则自动检测" FontSize="12" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Text="{Binding SteamPath, Mode=OneWay}" IsReadOnly="True" Width="240"
                                     Padding="8,6" Margin="0,0,8,0"/>
                            <Button Content="浏览" Command="{Binding BrowseSteamPathCommand}" Padding="12,6" Margin="0,0,4,0"/>
                            <Button Content="重置" Command="{Binding ResetSteamPathCommand}" Padding="12,6"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 自动监控 -->
                <Border Background="#28000000" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                        BorderBrush="#08FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="自动监控" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="文件变更时自动刷新游戏列表" FontSize="12" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="2" IsOn="{Binding IsAutoRefreshEnabled}"
                                         OnContent="开" OffContent="关" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>

            <!-- ============================================================ -->
            <!-- 高级设置 -->
            <!-- ============================================================ -->
            <StackPanel x:Name="AdvancedSection" Opacity="1" Visibility="Collapsed">

                <!-- 封面CDN节点 -->
                <Border Background="#28000000" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                        BorderBrush="#08FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="封面CDN节点" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="选择优先使用的封面下载节点" FontSize="12" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox ItemsSource="{Binding CdnEndpoints}"
                                      SelectedIndex="{Binding SelectedCdnIndex}"
                                      Width="220" Padding="8,4" Margin="0,0,8,0"/>
                            <Button Content="测速" Command="{Binding TestCdnSpeedCommand}"
                                    IsEnabled="{Binding IsSpeedTesting, Converter={StaticResource BoolInvertConverter}}"
                                    Padding="12,6"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 测速结果 -->
                <Border CornerRadius="8" Background="#18000000" Margin="16,8,16,0" Padding="12,8"
                        Visibility="{Binding SpeedTestResults.Count, Converter={StaticResource NonZeroToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding SpeedTestResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding ColorCode}"
                                             Margin="0,0,10,0" VerticalAlignment="Center" Opacity="0.9"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- 背景效果 -->
                <Border Background="#28000000" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                        BorderBrush="#08FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="背景效果" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="选择窗口背景效果" FontSize="12" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="2" ItemsSource="{Binding BackdropOptions}"
                                  SelectedValue="{Binding SelectedBackdrop}"
                                  SelectedValuePath="Value" DisplayMemberPath="Display"
                                  Width="220" Padding="8,4" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- 缓存管理 -->
                <Border Background="#28000000" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                        BorderBrush="#08FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="缓存管理" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="清理游戏名称和封面图片缓存" FontSize="12" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="清理缓存" Command="{Binding ClearCacheCommand}" Padding="12,6" Margin="0,0,4,0"/>
                            <Button Content="打开缓存目录" Command="{Binding OpenCacheFolderCommand}" Padding="12,6"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Lua 文件夹 -->
                <Border Background="#28000000" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                        BorderBrush="#08FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="Lua 文件夹" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="打开Steam Lua配置目录" FontSize="12" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="打开目录" Command="{Binding OpenLuaFolderCommand}" Padding="12,6"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>

            <!-- 状态信息 -->
            <TextBlock Text="{Binding StatusMessage}" Margin="0,16,0,0" FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
