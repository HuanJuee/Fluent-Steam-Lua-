<UserControl x:Class="SteamLuaManager.Views.ExtractionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="36,24,36,24">

            <TextBlock Text="Lua 提取" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="输入游戏 Steam ID 以指定提取该游戏的 Lua 清单（仅限登录的 Steam 账号已拥有的正版游戏）"
                       FontSize="12" Margin="0,0,0,24"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

            <!-- AppID 输入 + 选项 -->
            <Border Background="#28000000" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                    BorderBrush="#08FFFFFF" BorderThickness="1">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="AppID:" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>

                        <Grid Grid.Column="1" VerticalAlignment="Stretch">
                            <TextBlock Text="输入游戏 Steam ID"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, ElementName=AppIdBox}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="AppIdBox"
                                     Text="{Binding AppId, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8,6" Height="36" FontSize="14"
                                     VerticalContentAlignment="Center"
                                     HorizontalAlignment="Stretch"
                                     Background="Transparent"
                                     IsEnabled="{Binding IsRunning, Converter={StaticResource BoolInvertConverter}}"/>
                        </Grid>

                        <Button Grid.Column="2" Command="{Binding StartExtractionCommand}"
                                Padding="12,6" Height="36" Margin="8,0,4,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:FontIcon Glyph="&#xE768;" FontSize="14" Margin="0,0,6,0"
                                             Visibility="{Binding IsRunning, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                                <ui:FontIcon Glyph="&#xE71A;" FontSize="14" Margin="0,0,6,0"
                                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding IsRunning, Converter={StaticResource BoolToRunStopConverter}}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="3" Command="{Binding ClearLogCommand}"
                                Padding="12,6" Height="36" Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE74D;" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="清除日志" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <CheckBox Content="固定清单的游戏版本"
                              IsChecked="{Binding PinManifest}"
                              IsEnabled="{Binding IsRunning, Converter={StaticResource BoolInvertConverter}}"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              Margin="56,12,0,0" FontSize="13"/>

                    <TextBlock FontSize="12" Margin="56,4,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text='勾选时将写入"ManifestID"版本信息并固定'/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 日志区域 -->
            <Border Background="#18000000" CornerRadius="8" Padding="16"
                    BorderBrush="#08FFFFFF" BorderThickness="1" MinHeight="200">
                <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="LogScrollViewer_PreviewMouseWheel">
                    <ItemsControl ItemsSource="{Binding LogLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="13"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,1,0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
