<UserControl x:Class="SteamLuaManager.Views.ScriptDownloadView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        Background="Transparent">


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="36,24,36,24" HorizontalAlignment="Stretch">

            <!-- 页面标题 -->
            <TextBlock Text="游戏入库" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="支持通过游戏Steam ID和游戏名搜索（推荐使用英文名，中文名索引有问题容易搜不出来），支持模糊匹配，最多显示10条搜索结果"
                       FontSize="12" Margin="0,0,0,2"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <TextBlock Text="如出现搜索不出结果可尝试开VPN或代理"
                       FontSize="12" Margin="0,0,0,24"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

            <!-- 搜索卡片 -->
            <Border Background="#28000000" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                    BorderBrush="#08FFFFFF" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:AutoSuggestBox x:Name="SearchBox" Grid.Column="0"
                                       PlaceholderText="输入游戏名或Steam ID"
                                       Padding="8,6" Margin="0,0,8,0" Height="36"
                                       VerticalContentAlignment="Center"
                                       FontSize="14" MinWidth="200"
                                       HorizontalAlignment="Stretch"
                                       QuerySubmitted="SearchBox_QuerySubmitted"
                                       TextChanged="SearchBox_TextChanged"/>
                    <Button Grid.Column="1" Content="搜索" Command="{Binding SearchCommand}"
                            Padding="16,6" Height="36" FontSize="14"
                            IsEnabled="{Binding IsSearching, Converter={StaticResource BoolInvertConverter}}"/>
                    <Button Grid.Column="2" Content="清除日志" Command="{Binding ClearLogCommand}"
                            Padding="16,6" Height="36" FontSize="14" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- 日志区域 -->
            <Border Background="#18000000" CornerRadius="8" Padding="16"
                    BorderBrush="#08FFFFFF" BorderThickness="1" Margin="0,0,0,8" MinHeight="80">
                <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" PreviewMouseWheel="LogScrollViewer_PreviewMouseWheel">
                    <ItemsControl ItemsSource="{Binding LogLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="13"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,1,0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- 搜索结果列表 -->
            <ItemsControl ItemsSource="{Binding SearchResults}" Margin="0,0,0,8"
                          Visibility="{Binding SearchResults.Count, Converter={StaticResource NonZeroToVisibilityConverter}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#28000000" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                                BorderBrush="#08FFFFFF" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Source="{Binding CoverUrl}" Width="120" Height="52"
                                       Stretch="UniformToFill" Margin="0,0,16,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="2" Content="一键入库" Command="{Binding DataContext.DownloadGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="16,6" Height="36" FontSize="14"
                                        IsEnabled="{Binding DataContext.IsDownloading, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolInvertConverter}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
